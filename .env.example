DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_server_id

# Local storage path (default: mappings.json)
# MAPPINGS_FILE=mappings.json

# Supabase persistent storage (optional, recommended for deployed admin panel)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-or-service-key
# SUPABASE_TABLE=mappings
# SUPABASE_ROW_ID=default

# Optional: for AI-powered formatting (supports OpenAI, OpenRouter, etc.)
OPENAI_API_KEY=your_api_key_here
# Or use OpenRouter:
# OPEN_ROUTER_API_KEY=your_openrouter_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini

# Optional settings (uncomment to override defaults)
# USE_AI_FORMATTER=false
# BANNED_WORDS=spam,scam,nsfw
# RATE_LIMIT_SECONDS=10
